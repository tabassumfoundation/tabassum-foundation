        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="font-semibold text-white mb-4 text-sm uppercase tracking-wider">Quick Links</h4>
        <ul class="space-y-2.5">
          <li><a href="/" class="text-gray-400 hover:text-teal-400 text-sm transition-colors">Home</a></li>
          <li><a href="/about" class="text-gray-400 hover:text-teal-400 text-sm transition-colors">About Us</a></li>
          <li><a href="/activities" class="text-gray-400 hover:text-teal-400 text-sm transition-colors">Our Activities</a></li>
          <li><a href="/donate" class="text-gray-400 hover:text-teal-400 text-sm transition-colors">Donate</a></li>
          <li><a href="/contact" class="text-gray-400 hover:text-teal-400 text-sm transition-colors">Contact Us</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-semibold text-white mb-4 text-sm uppercase tracking-wider">Contact</h4>
        <ul class="space-y-3">
          <li class="flex gap-3 text-sm text-gray-400">
            <svg class="w-4 h-4 text-teal-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            315 Saddar Cant, Peshawar, Pakistan
          </li>
          <li class="flex gap-3 text-sm">
            <svg class="w-4 h-4 text-teal-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            <a href="tel:+923407119755" class="text-gray-400 hover:text-teal-400 transition-colors">+92 340 711 9755</a>
          </li>
          <li class="flex gap-3 text-sm">
            <svg class="w-4 h-4 text-teal-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            <a href="mailto:tabassumfoundation7@gmail.com" class="text-gray-400 hover:text-teal-400 transition-colors">tabassumfoundation7@gmail.com</a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/10 pt-6 flex flex-col md:flex-row justify-between items-center gap-3">
      <p class="text-gray-500 text-xs">
        © 2026 Tabassum Foundation. All rights reserved. Registered non-profit organization.
      </p>
      <p class="text-gray-600 text-xs">
        Built with ❤️ for a brighter Pakistan
      </p>
    </div>
  </div>
</footer>
