---
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

export const prerender = true;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title="Contact Us – Tabassum Foundation">
  <Navbar transparent={true} />

  <section class="hero-video-container">
    <video autoplay muted loop playsinline preload="none"
      style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0;"
      aria-hidden="true">
      <source src={`${base}/video/contact.webm`} type="video/webm" />
      <source src={`${base}/video/contact.mp4`} type="video/mp4" />
    </video>
    <div class="hero-overlay" style="background:linear-gradient(135deg,rgba(13,92,88,0.82) 0%,rgba(13,92,88,0.52) 60%,rgba(0,0,0,0.45) 100%);"></div>
    <div class="hero-content max-w-7xl mx-auto w-full px-6 md:px-12" style="margin-top:-80px;">
      <div class="max-w-2xl">
        <span class="inline-block text-teal-300 text-sm font-semibold tracking-widest uppercase mb-4 opacity-90">Get in Touch</span>
        <h1 class="font-display text-white text-5xl md:text-6xl font-bold leading-tight mb-5">
          Contact <em class="text-teal-200 not-italic">Us</em>
        </h1>
        <p class="text-white/80 text-lg leading-relaxed max-w-lg">
          We'd love to hear from you. Whether you have questions, want to volunteer,
          or support our programs — reach out!
        </p>
        <div class="flex flex-wrap gap-4 mt-8">
          <a href="/donate" class="btn-primary py-3 px-7">Donate Now ♥</a>
          <a href="#contact-form-section" class="btn-outline py-3 px-7">Send a Message →</a>
        </div>
      </div>
    </div>
  </section>

  <section id="contact-form-section" class="py-20 px-6 md:px-12 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-2 gap-16">

        <div class="reveal">
          <span class="section-label">Reach Us</span>
          <h2 class="section-title mt-2 mb-8">Let's connect</h2>

          <div class="space-y-6">
            <div class="flex gap-4 items-start">
              <div class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0"
                style="background: linear-gradient(135deg, #d9f2ef, #b3e5e0);">
                <svg class="w-5 h-5 text-teal-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div>
                <h4 class="font-semibold text-gray-800 mb-1">Address</h4>
                <p class="text-gray-500 text-sm leading-relaxed">
                  315 Saddar Cant,<br />Peshawar, Pakistan
                </p>
              </div>
            </div>

            <div class="flex gap-4 items-start">
              <div class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0"
                style="background: linear-gradient(135deg, #d9f2ef, #b3e5e0);">
                <svg class="w-5 h-5 text-teal-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </div>
              <div>
                <h4 class="font-semibold text-gray-800 mb-1">Phone</h4>
                <a href="tel:+923407119755" class="text-teal-600 hover:text-teal-800 font-medium transition-colors">
                  +92 340 711 9755
                </a>
              </div>
            </div>

            <div class="flex gap-4 items-start">
              <div class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0"
                style="background: linear-gradient(135deg, #d9f2ef, #b3e5e0);">
                <svg class="w-5 h-5 text-teal-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <h4 class="font-semibold text-gray-800 mb-1">Email</h4>
                <a href="mailto:tabassumfoundation7@gmail.com" class="text-teal-600 hover:text-teal-800 font-medium transition-colors text-sm">
                  tabassumfoundation7@gmail.com
                </a>
              </div>
            </div>

            <div class="flex gap-4 items-start">
              <div class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0"
                style="background: linear-gradient(135deg, #d9f2ef, #b3e5e0);">
                <svg class="w-5 h-5 text-teal-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9"/>
                </svg>
              </div>
              <div>
                <h4 class="font-semibold text-gray-800 mb-1">Website</h4>
                <a href="https://tabasumfoundation.org" class="text-teal-600 hover:text-teal-800 font-medium transition-colors text-sm">
                  tabasumfoundation.org
                </a>
              </div>
            </div>
          </div>

          <div class="mt-8">
            <h4 class="font-semibold text-gray-700 mb-4 text-sm">Follow Us</h4>
            <div class="flex gap-3">
              <a href="https://www.tiktok.com/@tabassumfoundation" target="_blank" rel="noopener"
                class="flex items-center gap-2 text-xs text-gray-600 bg-gray-50 hover:bg-teal-50 hover:text-teal-700 px-3 py-2 rounded-lg border border-gray-200 transition-colors">
                TikTok @tabassumfoundation
              </a>
            </div>
          </div>
        </div>

        <div class="reveal" style="transition-delay: 0.2s">
          <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100">
            <h3 class="font-display text-xl font-semibold text-gray-800 mb-6">Send us a message</h3>

            <form id="contact-form" class="space-y-4" novalidate>
              <div class="grid grid-cols-2 gap-4">
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1.5">First Name</label>
                  <input type="text" name="firstName" required placeholder="Ahmed"
                    class="w-full px-4 py-3 rounded-lg border border-gray-200 bg-white text-sm focus:outline-none focus:border-teal-400 focus:ring-2 focus:ring-teal-100" />
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1.5">Last Name</label>
                  <input type="text" name="lastName" placeholder="Khan"
                    class="w-full px-4 py-3 rounded-lg border border-gray-200 bg-white text-sm focus:outline-none focus:border-teal-400 focus:ring-2 focus:ring-teal-100" />
                </div>
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5">Email Address</label>
                <input type="email" name="email" required placeholder="you@example.com"
                  class="w-full px-4 py-3 rounded-lg border border-gray-200 bg-white text-sm focus:outline-none focus:border-teal-400 focus:ring-2 focus:ring-teal-100" />
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5">Phone (optional)</label>
                <input type="tel" name="phone" placeholder="+92 300 0000000"
                  class="w-full px-4 py-3 rounded-lg border border-gray-200 bg-white text-sm focus:outline-none focus:border-teal-400 focus:ring-2 focus:ring-teal-100" />
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5">Subject</label>
                <select name="subject"
                  class="w-full px-4 py-3 rounded-lg border border-gray-200 bg-white text-sm focus:outline-none focus:border-teal-400 focus:ring-2 focus:ring-teal-100 text-gray-600">
                  <option value="">Select a subject</option>
                  <option>General Inquiry</option>
                  <option>Volunteer</option>
                  <option>Donation</option>
                  <option>Partnership</option>
                  <option>Media</option>
                </select>
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5">Message</label>
                <textarea name="message" required rows="4" placeholder="How can we help you?"
                  class="w-full px-4 py-3 rounded-lg border border-gray-200 bg-white text-sm focus:outline-none focus:border-teal-400 focus:ring-2 focus:ring-teal-100 resize-none"></textarea>
              </div>

              <button type="submit" class="w-full btn-primary py-3.5 justify-center text-base" id="submit-btn">
                Send Message →
              </button>

              <div id="form-success" class="hidden p-4 bg-teal-50 border border-teal-200 rounded-lg text-teal-700 text-sm text-center">
                ✅ Message sent! We'll get back to you soon.
              </div>
            </form>
          </div>
        </div>
      </div>

      <div class="reveal mt-16">
        <h3 class="font-display text-xl font-semibold text-gray-800 mb-4">Find Us</h3>
        <div class="rounded-2xl overflow-hidden shadow-sm border border-gray-100 h-72">
          <iframe
            title="Tabassum Foundation Location"
            src="https://maps.google.com/maps?q=315+Saddar+Cant+Peshawar+Pakistan&t=m&z=15&output=embed&iwloc=near"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Base>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMsg = document.getElementById('form-success');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();

    const data = new FormData(form);
    const mailto = `mailto:tabassumfoundation7@gmail.com?subject=${encodeURIComponent(data.get('subject') as string || 'Website Inquiry')}&body=${encodeURIComponent(
      `Name: ${data.get('firstName')} ${data.get('lastName')}\nEmail: ${data.get('email')}\nPhone: ${data.get('phone')}\n\nMessage:\n${data.get('message')}`
    )}`;

    window.location.href = mailto;

    successMsg?.classList.remove('hidden');
    form.reset();
    submitBtn.textContent = 'Message Sent ✓';
    submitBtn.disabled = true;
  });
</script>
