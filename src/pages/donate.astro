---
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

export const prerender = true;

---

<Base title="Donate – Tabassum Foundation">
  <Navbar />

  <!-- Header -->
  <div class="pt-28 pb-16 px-6 md:px-12 text-white" style="background: linear-gradient(135deg, #0d5c58 0%, #1a9990 100%);">
    <div class="max-w-3xl mx-auto text-center">
      <span class="inline-block text-teal-200 text-sm font-semibold tracking-widest uppercase mb-3">Make a Difference</span>
      <h1 class="font-display text-5xl md:text-6xl font-bold mb-4">Donate</h1>
      <p class="text-teal-100 text-lg max-w-xl mx-auto">
        Your generous contribution directly supports children and families in need across Pakistan.
      </p>
    </div>
  </div>

  <section class="py-20 px-6 md:px-12 bg-white">
    <div class="max-w-5xl mx-auto">

      <!-- Why Donate -->
      <div class="text-center mb-16 reveal">
        <span class="section-label">Why Donate</span>
        <h2 class="section-title mt-2 mb-4">Every rupee creates impact</h2>
        <p class="text-gray-500 max-w-xl mx-auto">
          Donations fund school supplies, nutritious food programs, child protection initiatives,
          and vocational training for mothers across Pakistan.
        </p>
      </div>

      <!-- Payment Methods -->
      <div class="reveal mb-10">
        <h3 class="font-display text-xl font-semibold text-gray-800 mb-6">Choose Payment Method</h3>
        <div class="grid md:grid-cols-2 gap-6">

          <!-- JazzCash -->
          <div class="payment-placeholder card-hover">
            <div class="flex items-center justify-center gap-3 mb-4">
              <!-- JazzCash logo color: #EE3124 -->
              <div class="w-12 h-12 rounded-full flex items-center justify-center font-bold text-white text-lg"
                style="background: linear-gradient(135deg, #EE3124, #c02519);">
                J
              </div>
              <div>
                <h4 class="font-bold text-gray-800 text-lg">JazzCash</h4>
                <p class="text-gray-400 text-xs">Mobile Wallet Payment</p>
              </div>
            </div>
            <div class="bg-orange-50 border border-orange-200 rounded-lg p-4 mb-4">
              <p class="text-orange-700 text-sm font-medium text-center">
                📱 JazzCash Account Number
              </p>
              <p class="text-center text-2xl font-bold text-orange-600 mt-1" id="jazzcash-number">
                XXXX-XXXXXXX
              </p>

            </div>
            <p class="text-gray-500 text-sm text-center leading-relaxed">
              Send your donation to the JazzCash number above and
              send proof to <strong>tabassumfoundation7@gmail.com</strong>
            </p>
            <a href="mailto:tabassumfoundation7@gmail.com?subject=JazzCash Donation"
              class="mt-4 w-full btn-primary justify-center text-center block py-3">
              Confirm via Email
            </a>
          </div>

          <!-- Easypaisa -->
          <div class="payment-placeholder card-hover">
            <div class="flex items-center justify-center gap-3 mb-4">
              <!-- Easypaisa logo color: #009644 -->
              <div class="w-12 h-12 rounded-full flex items-center justify-center font-bold text-white text-lg"
                style="background: linear-gradient(135deg, #009644, #007a36);">
                E
              </div>
              <div>
                <h4 class="font-bold text-gray-800 text-lg">Easypaisa</h4>
                <p class="text-gray-400 text-xs">Mobile Wallet Payment</p>
              </div>
            </div>
            <div class="bg-green-50 border border-green-200 rounded-lg p-4 mb-4">
              <p class="text-green-700 text-sm font-medium text-center">
                📱 Easypaisa Account Number
              </p>
              <p class="text-center text-2xl font-bold text-green-600 mt-1" id="easypaisa-number">
                XXXX-XXXXXXX
              </p>

            </div>
            <p class="text-gray-500 text-sm text-center leading-relaxed">
              Send your donation to the Easypaisa number above and
              send proof to <strong>tabassumfoundation7@gmail.com</strong>
            </p>
            <a href="mailto:tabassumfoundation7@gmail.com?subject=Easypaisa Donation"
              class="mt-4 w-full btn-primary justify-center text-center block py-3"
              style="background: #009644;">
              Confirm via Email
            </a>
          </div>
        </div>
      </div>

      <!-- Bank Transfer Option -->
      <div class="reveal bg-gray-50 rounded-2xl p-6 border border-gray-200 text-center">
        <h4 class="font-semibold text-gray-700 mb-2">📋 Bank Transfer</h4>
        <p class="text-gray-500 text-sm">
          For large donations or bank transfers, please contact us directly at
          <a href="mailto:tabassumfoundation7@gmail.com" class="text-teal-600 hover:underline font-medium">
            tabassumfoundation7@gmail.com
          </a>
          and we will provide bank account details.
        </p>
      </div>

      <!-- Reassurance -->
      <div class="reveal mt-12 grid grid-cols-1 md:grid-cols-3 gap-6 text-center">
        <div class="p-5">
          <div class="text-3xl mb-3">🔒</div>
          <h4 class="font-semibold text-gray-700 text-sm mb-1">100% Transparent</h4>
          <p class="text-gray-400 text-xs">Every donation is tracked and reported.</p>
        </div>
        <div class="p-5">
          <div class="text-3xl mb-3">💚</div>
          <h4 class="font-semibold text-gray-700 text-sm mb-1">Directly Impacts Lives</h4>
          <p class="text-gray-400 text-xs">Funds go directly to programs, not overhead.</p>
        </div>
        <div class="p-5">
          <div class="text-3xl mb-3">📜</div>
          <h4 class="font-semibold text-gray-700 text-sm mb-1">Registered Non-Profit</h4>
          <p class="text-gray-400 text-xs">Tabassum Foundation is a registered organization.</p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Base>


